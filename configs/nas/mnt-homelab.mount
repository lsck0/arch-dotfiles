[Unit]
Description=NAS homelab share (nas.lsck0.dev)
DefaultDependencies=no
Conflicts=umount.target
Before=umount.target
After=network-online.target
Wants=network-online.target

[Mount]
What=//smb.lsck0.dev/homelab
Where=/mnt/homelab
Type=cifs
Options=guest,uid=1000,gid=1000,vers=3.0,_netdev,file_mode=0664,dir_mode=0775

[Install]
WantedBy=multi-user.target
